<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base dark KaiOS-style theme used by settings/drawer screens. -->
    <style name="Theme.FlipLauncher" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/kai_bg</item>
        <item name="android:colorBackground">@color/kai_bg</item>
        <item name="android:statusBarColor">@color/kai_softkey_bg</item>
        <item name="android:navigationBarColor">@color/kai_softkey_bg</item>
        <item name="colorAccent">@color/kai_accent</item>
        <item name="android:textColorPrimary">@color/kai_text</item>
        <item name="android:textColorSecondary">@color/kai_text_secondary</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Home screen: show the user's wallpaper behind the clock & shortcuts.
         The scrim lives on the window background (not the content view) so it
         extends behind the status bar instead of being clipped by
         fitsSystemWindows, keeping the status bar's darkening consistent with
         the rest of the screen. -->
    <style name="Theme.FlipLauncher.Home" parent="Theme.FlipLauncher">
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowBackground">@drawable/bg_home_scrim</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- App drawer: wallpaper behind a translucent black scrim, edge to edge,
         matching the rest of the KaiOS chrome instead of a solid bar. -->
    <style name="Theme.FlipLauncher.Drawer" parent="Theme.FlipLauncher.Home">
        <item name="android:windowBackground">@color/kai_overlay</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Accent color overlays applied at runtime (see LauncherPrefs.AccentColor)
         on top of whichever base theme an activity already uses, so every
         ?attr/colorAccent reference in drawables/layouts follows the user's pick. -->
    <style name="ThemeOverlay.FlipLauncher.Accent.Red" parent="">
        <item name="colorAccent">@color/kai_accent_red</item>
    </style>
    <style name="ThemeOverlay.FlipLauncher.Accent.Orange" parent="">
        <item name="colorAccent">@color/kai_accent_orange</item>
    </style>
    <style name="ThemeOverlay.FlipLauncher.Accent.Yellow" parent="">
        <item name="colorAccent">@color/kai_accent_yellow</item>
    </style>
    <style name="ThemeOverlay.FlipLauncher.Accent.Green" parent="">
        <item name="colorAccent">@color/kai_accent_green</item>
    </style>
    <style name="ThemeOverlay.FlipLauncher.Accent.Blue" parent="">
        <item name="colorAccent">@color/kai_accent_blue</item>
    </style>
    <style name="ThemeOverlay.FlipLauncher.Accent.Indigo" parent="">
        <item name="colorAccent">@color/kai_accent_indigo</item>
    </style>
    <style name="ThemeOverlay.FlipLauncher.Accent.Violet" parent="">
        <item name="colorAccent">@color/kai_accent_violet</item>
    </style>
</resources>
