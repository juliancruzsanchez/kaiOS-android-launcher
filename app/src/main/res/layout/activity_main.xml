<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Left shortcut rail (keys 1-9, top to bottom) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/shortcuts_rail"
        android:layout_width="84dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_rail_panel"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/home_softkeys"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Big clock + date, right-aligned. Every line is single-line and auto-sizes
         so it never wraps, regardless of screen width / aspect ratio. -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="18dp"
        android:gravity="end"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/shortcuts_rail"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/ampm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:singleLine="true"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="6"
            android:textColor="@color/kai_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/clock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-4dp"
            app:autoSizeMaxTextSize="76sp"
            app:autoSizeMinTextSize="34sp"
            app:autoSizeStepGranularity="2sp"
            app:autoSizeTextType="uniform"
            android:fontFamily="sans-serif-light"
            android:gravity="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="8"
            android:textColor="@color/kai_text"
            android:textSize="76sp" />

        <TextView
            android:id="@+id/weekday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:autoSizeMaxTextSize="20sp"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform"
            android:gravity="end"
            android:letterSpacing="0.04"
            android:maxLines="1"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="6"
            android:textAllCaps="true"
            android:textColor="@color/kai_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/date_line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:autoSizeMaxTextSize="20sp"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform"
            android:gravity="end"
            android:letterSpacing="0.04"
            android:maxLines="1"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="6"
            android:textAllCaps="true"
            android:textColor="@color/kai_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/notif_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/notif_calls_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@string/cd_notif_calls"
                    android:src="@drawable/ic_call" />

                <TextView
                    android:id="@+id/notif_calls_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="6"
                    android:textColor="@color/kai_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/notif_messages_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@string/cd_notif_messages"
                    android:src="@drawable/ic_message" />

                <TextView
                    android:id="@+id/notif_messages_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="6"
                    android:textColor="@color/kai_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/notif_other_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@string/cd_notif_other"
                    android:src="@drawable/ic_notification" />

                <TextView
                    android:id="@+id/notif_other_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="6"
                    android:textColor="@color/kai_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Soft keys over the wallpaper: Notices | apps | Contacts -->
    <LinearLayout
        android:id="@+id/home_softkeys"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/softkey_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:focusable="false"
            android:gravity="start|center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="8dp"
            android:shadowColor="#A6000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="5"
            android:text="@string/softkey_notifications"
            android:textColor="@color/kai_text"
            android:textSize="15sp"
            tools:ignore="RtlSymmetry"
            xmlns:tools="http://schemas.android.com/tools" />

        <ImageView
            android:id="@+id/softkey_center"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/bg_rail_focus"
            android:clickable="true"
            android:contentDescription="@string/content_apps"
            android:focusable="true"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:scaleType="center"
            android:src="@drawable/ic_apps_dots" />

        <TextView
            android:id="@+id/softkey_right"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:focusable="false"
            android:gravity="end|center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="18dp"
            android:shadowColor="#A6000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="5"
            android:text="@string/softkey_contacts"
            android:textColor="@color/kai_text"
            android:textSize="15sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
