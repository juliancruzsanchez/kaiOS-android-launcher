<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Needed for WallpaperManager.setBitmap() in the bundled Wallpaper Picker. -->
    <uses-permission android:name="android.permission.SET_WALLPAPER" />

    <!--
      A launcher only needs to see launchable activities and the dialer.
      Using a <queries> block keeps us off the sensitive QUERY_ALL_PACKAGES
      permission while still letting us enumerate every app the user can open.
    -->

    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FlipLauncher">

        <!-- Home screen. Registering for CATEGORY_HOME makes this selectable
             as the default launcher. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FlipLauncher.Home"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:excludeFromRecents="true"
            android:resizeableActivity="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="stateAlwaysHidden"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize|screenLayout|smallestScreenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LauncherSettingsActivity"
            android:exported="true"
            android:icon="@drawable/settings_112"
            android:label="@string/title_launcher_settings"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AppDrawerActivity"
            android:exported="false"
            android:theme="@style/Theme.FlipLauncher.Drawer"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize" />

        <activity
            android:name=".OptionsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize" />

        <activity
            android:name=".HideAppsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize" />

        <activity
            android:name=".ShortcutConfigActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize" />

        <activity
            android:name=".AppPickerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize" />

        <activity
            android:name=".ActivityPickerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize" />

        <activity
            android:name=".IconPackActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize" />

        <activity
            android:name=".IconPickerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize" />

        <activity
            android:name=".WallpaperPickerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize" />

        <activity
            android:name=".NoticesActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|keyboard|navigation|orientation|screenSize" />

        <!-- Feeds the Home notification summary (calls/messages/other) and the
             custom Notices screen. Requires the user to grant Notification
             Access in system settings. -->
        <service
            android:name=".service.NotificationCountService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>

</manifest>
